  propertyUnit       PropertyUnit?         @relation(fields: [propertyUnitId], references: [id])
  user               User                  @relation(fields: [userId], references: [id])
  marketer           TeamMember?           @relation("SelectedMarketerTransactions", fields: [marketerId], references: [id])
