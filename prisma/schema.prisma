generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum AppRole {
  BUYER
  STAFF
  ADMIN
  LEGAL
  FINANCE
  SUPER_ADMIN
}

enum PropertyStatus {
  DRAFT
  AVAILABLE
  RESERVED
  SOLD
  ARCHIVED
}

enum PropertyVerificationStatus {
  VERIFIED
  STALE
  UNVERIFIED
  HIDDEN
}

enum PropertyType {
  APARTMENT
  DUPLEX
  TERRACE
  DETACHED
  SEMI_DETACHED
  LAND
  COMMERCIAL
}

enum LeadSource {
  WEBSITE
  WALK_IN
  REFERRAL
  WHATSAPP
  SOCIAL_MEDIA
  PAID_ADS
  AGENT
  PARTNER
}

enum InquiryStatus {
  NEW
  QUALIFIED
  CONTACTED
  INSPECTION_BOOKED
  CONVERTED
  CLOSED
  LOST
}

enum InspectionStatus {
  PENDING
  REQUESTED
  CONFIRMED
  RESCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum ReservationStatus {
  PENDING
  ACTIVE
  EXPIRED
  CANCELLED
  CONVERTED
}

enum TransactionStage {
  INQUIRY_RECEIVED
  KYC_SUBMITTED
  RESERVATION_FEE_PAID
  CONTRACT_ISSUED
  ALLOCATION_IN_PROGRESS
  LEGAL_VERIFICATION
  FINAL_PAYMENT_COMPLETED
  HANDOVER_COMPLETED
}

enum PaymentPlanKind {
  ONE_TIME
  FIXED
  CUSTOM
}

enum MilestoneStatus {
  PENDING
  ACTIVE
  COMPLETED
  BLOCKED
}

enum KycStatus {
  NOT_SUBMITTED
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  CHANGES_REQUESTED
}

enum BillingInterval {
  MONTHLY
  ANNUAL
}

enum SubscriptionStatus {
  ACTIVE
  TRIAL
  GRANTED
  EXPIRED
  CANCELLED
  PAST_DUE
}

enum BillingEventType {
  PLAN_ASSIGNED
  PLAN_GRANTED
  PLAN_REVOKED
  SUBSCRIPTION_RENEWED
  SUBSCRIPTION_CANCELLED
  SUBSCRIPTION_PAYMENT_RECORDED
}

enum CommissionType {
  FLAT
  PERCENTAGE
}

enum SettlementStatus {
  PENDING
  READY
  SUBMITTED
  SETTLED
  FAILED
  NOT_APPLICABLE
}

enum MarketerCommissionStatus {
  PENDING
  PAID
  VOIDED
}

enum ProviderAccountStatus {
  PENDING
  ACTIVE
  DISABLED
}

enum PaymentProviderCode {
  PAYSTACK
  FLUTTERWAVE
  STRIPE
  MANUAL
}

enum PaymentStatus {
  AWAITING_INITIATION
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  EXPIRED
  REFUNDED
  OVERDUE
}

enum DealPaymentStatus {
  PENDING
  PARTIAL
  COMPLETED
  OVERDUE
}

enum PaymentMethod {
  PAYSTACK
  BANK_TRANSFER
  CARD
  CASH
}

enum PaymentRequestStatus {
  DRAFT
  SENT
  AWAITING_PAYMENT
  PAID
  EXPIRED
  CANCELLED
}

enum PaymentRequestChannel {
  IN_APP
  EMAIL
  SHARE_LINK
}

enum PaymentRequestCollectionMethod {
  HOSTED_CHECKOUT
  BANK_TRANSFER_TEMP_ACCOUNT
  DEDICATED_VIRTUAL_ACCOUNT
  MANUAL_BANK_TRANSFER_REFERENCE
  CARD_LINK
}

enum DocumentType {
  KYC_ID
  KYC_PROOF_OF_ADDRESS
  PASSPORT_PHOTO
  RECEIPT
  CONTRACT
  BROCHURE
  AGREEMENT
  OTHER
}

enum DocumentVisibility {
  PUBLIC
  PRIVATE
}

enum NotificationType {
  INQUIRY_RECEIVED
  INQUIRY_ASSIGNED
  INSPECTION_BOOKED
  INSPECTION_UPDATED
  PROPERTY_VERIFICATION_DUE
  PROPERTY_HIDDEN
  WISHLIST_ADDED
  WISHLIST_EXPIRING
  RESERVATION_CREATED
  PAYMENT_CONFIRMED
  DOCUMENT_REQUESTED
  KYC_REVIEWED
  MILESTONE_UPDATED
  RECEIPT_AVAILABLE
  INSTALLMENT_DUE
  PAYMENT_REQUEST_SENT
  PAYMENT_REQUEST_PAID
  PAYMENT_REQUEST_EXPIRED
  SYSTEM
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
  WHATSAPP
}

enum WishlistStatus {
  ACTIVE
  EXPIRED
  REMOVED
}

enum FollowUpStatus {
  NONE
  PENDING_CALL
  CONTACTED
  PROMISED_TO_PAY
  NOT_REACHABLE
  FOLLOW_UP_SCHEDULED
  CLOSED
}

enum CompanyStatus {
  ACTIVE
  SUSPENDED
  DISABLED
}

enum AnalyticsScope {
  PLATFORM
  COMPANY
}

enum DevelopmentSaleMode {
  PER_SQM
  PER_PLOT
  MIXED
}

enum DevelopmentPaymentMode {
  OUTRIGHT
  INSTALLMENT
}

enum DevelopmentSalesMixPriceMode {
  PER_SQM
  PER_UNIT
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  VERIFY
  APPROVE
  REJECT
  LOGIN
  PAYMENT
  BILLING
}

model Company {
  id              String             @id @default(cuid())
  name            String
  slug            String             @unique
  status          CompanyStatus      @default(ACTIVE)
  suspendedAt     DateTime?
  suspensionReason String?
  description     String?
  legalName       String?
  subdomain       String?            @unique
  customDomain    String?            @unique
  logoUrl         String?
  primaryColor    String?
  accentColor     String?
  brandSettings   Json?
  users           User[]
  userRoles       UserRole[]
  roles           Role[]
  branches        Branch[]
  properties      Property[]
  propertyUnits   PropertyUnit[]
  propertyMedia   PropertyMedia[]
  propertyFeatures PropertyFeature[]
  propertyLocations PropertyLocation[]
  savedProperties SavedProperty[]
  inquiries       Inquiry[]
  inspections     InspectionBooking[]
  reservations    Reservation[]
  transactions    Transaction[]
  milestones      TransactionMilestone[]
  paymentPlans    PaymentPlan[]
  installments    Installment[]
  payments        Payment[]
  paymentRequests PaymentRequest[]
  receipts        Receipt[]
  documents       Document[]
  kycSubmissions  KYCSubmission[]
  signedAgreements SignedAgreement[]
  documentAccessLogs DocumentAccessLog[]
  blogPosts       BlogPost[]
  testimonials    Testimonial[]
  teamMembers     TeamMember[]
  faqItems        FAQItem[]
  siteSetting     SiteSettings?
  notifications   Notification[]
  auditLogs       AuditLog[]
  activityEvents  ActivityEvent[]
  webhookEvents   WebhookEvent[]
  backgroundJobs  BackgroundJobLog[]
  analyticsSnapshots AnalyticsDailySnapshot[]
  developmentCalculations DevelopmentCalculation[]
  developmentCalculationPhases DevelopmentCalculationPhase[]
  developmentSalesMixItems DevelopmentCalculationSalesMixItem[]
  billingSettings CompanyBillingSettings?
  subscriptions   CompanySubscription[]
  providerAccounts CompanyPaymentProviderAccount[]
  teamInvitations TeamMemberInvitation[]
  commissionRules CommissionRule[]
  commissionRecords CommissionRecord[]
  splitSettlements SplitSettlement[]
  marketerCommissionRules MarketerCommissionRule[] @relation("CompanyMarketerCommissionRules")
  marketerCommissions     MarketerCommission[]     @relation("CompanyMarketerCommissions")
    billingEvents   BillingEvent[]
    marketerRankingSnapshots MarketerRankingSnapshot[]
    createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  @@index([status, createdAt])
}

model DevelopmentCalculation {
    id                                   String                   @id @default(cuid())
    companyId                            String
    versionGroupId                       String?
    versionNumber                        Int                      @default(1)
    versionLabel                         String?
    sourcePresetKey                      String?
    createdByUserId                      String?
    updatedByUserId                      String?
  projectName                          String
  location                             String?
  notes                                String?
  currency                             String                   @default("NGN")
  landSizeHectares                     Decimal                  @db.Decimal(12, 4)
  landPurchasePrice                    Decimal                  @db.Decimal(14, 2)
  purchaseDate                         DateTime?
  projectDurationMonths                Int
  salesDurationMonths                  Int
  roadsPercentage                      Decimal                  @default(0) @db.Decimal(5, 2)
  drainagePercentage                   Decimal                  @default(0) @db.Decimal(5, 2)
  greenAreaPercentage                  Decimal                  @default(0) @db.Decimal(5, 2)
  utilitiesPercentage                  Decimal                  @default(0) @db.Decimal(5, 2)
  surveyCost                           Decimal                  @default(0) @db.Decimal(14, 2)
  legalDocumentationCost               Decimal                  @default(0) @db.Decimal(14, 2)
  titlePerfectionCost                  Decimal                  @default(0) @db.Decimal(14, 2)
  siteClearingCost                     Decimal                  @default(0) @db.Decimal(14, 2)
  sandFillingEarthworkCost             Decimal                  @default(0) @db.Decimal(14, 2)
  roadConstructionCost                 Decimal                  @default(0) @db.Decimal(14, 2)
  drainageCost                         Decimal                  @default(0) @db.Decimal(14, 2)
  powerInfrastructureCost              Decimal                  @default(0) @db.Decimal(14, 2)
  waterInfrastructureCost              Decimal                  @default(0) @db.Decimal(14, 2)
  fencingGatehouseSecurityCost         Decimal                  @default(0) @db.Decimal(14, 2)
  marketingSalesCommissionCost         Decimal                  @default(0) @db.Decimal(14, 2)
  adminCost                            Decimal                  @default(0) @db.Decimal(14, 2)
  contingencyCost                      Decimal                  @default(0) @db.Decimal(14, 2)
  annualInflationRate                  Decimal                  @default(0) @db.Decimal(5, 2)
  constructionCostEscalationRate       Decimal                  @default(0) @db.Decimal(5, 2)
  annualSellingPriceAppreciationRate   Decimal                  @default(0) @db.Decimal(5, 2)
  marketRiskPremiumRate                Decimal                  @default(0) @db.Decimal(5, 2)
  financingCostRate                    Decimal                  @default(0) @db.Decimal(5, 2)
  requiredTargetProfitMarginRate       Decimal                  @default(0) @db.Decimal(5, 2)
  saleMode                             DevelopmentSaleMode      @default(PER_SQM)
  currentSellingPricePerSqm            Decimal?                 @db.Decimal(14, 2)
  paymentMode                          DevelopmentPaymentMode   @default(OUTRIGHT)
  installmentTenureMonths              Int?
  installmentPremiumRate               Decimal?                 @db.Decimal(5, 2)
  useInflationAdjustedInstallmentPricing Boolean                @default(false)
  archivedAt                           DateTime?
  company                              Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  salesMixItems                        DevelopmentCalculationSalesMixItem[]
  phases                               DevelopmentCalculationPhase[]
    createdAt                            DateTime                 @default(now())
    updatedAt                            DateTime                 @updatedAt
  
    @@index([companyId, archivedAt, updatedAt])
    @@index([companyId, projectName])
    @@index([companyId, versionGroupId, archivedAt, updatedAt])
  }

model DevelopmentCalculationSalesMixItem {
  id            String                       @id @default(cuid())
  companyId     String
  calculationId String
  label         String
  quantity      Int
  sizeSqm       Decimal                      @db.Decimal(10, 2)
  priceMode     DevelopmentSalesMixPriceMode @default(PER_UNIT)
  pricePerSqm   Decimal?                     @db.Decimal(14, 2)
  unitPrice     Decimal?                     @db.Decimal(14, 2)
  displayOrder  Int                          @default(0)
  company       Company                      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  calculation   DevelopmentCalculation       @relation(fields: [calculationId], references: [id], onDelete: Cascade)
  createdAt     DateTime                     @default(now())
  updatedAt     DateTime                     @updatedAt

  @@index([companyId, calculationId])
  @@index([calculationId, displayOrder])
}

model DevelopmentCalculationPhase {
  id                     String                 @id @default(cuid())
  companyId              String
  calculationId          String
  name                   String
  startMonthOffset       Int                    @default(0)
  durationMonths         Int                    @default(1)
  developmentCostShare   Decimal                @default(0) @db.Decimal(5, 2)
  sellableInventoryShare Decimal                @default(0) @db.Decimal(5, 2)
  sellingPriceOverridePerSqm Decimal?           @db.Decimal(14, 2)
  sellingPriceUpliftRate Decimal?               @db.Decimal(6, 2)
  salesVelocityRate      Decimal                @default(100) @db.Decimal(5, 2)
  notes                  String?
  displayOrder           Int                    @default(0)
  company                Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  calculation            DevelopmentCalculation @relation(fields: [calculationId], references: [id], onDelete: Cascade)
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt

  @@index([companyId, calculationId])
  @@index([calculationId, displayOrder])
}

model AnalyticsDailySnapshot {
  id                     String         @id @default(cuid())
  scope                  AnalyticsScope
  scopeKey               String         @default("global")
  companyId              String?
  bucketDate             DateTime
  totalCompanies         Int            @default(0)
  activeCompanies        Int            @default(0)
  newCompanies           Int            @default(0)
  inquiryCount           Int            @default(0)
  reservationCount       Int            @default(0)
  dealCount              Int            @default(0)
  paymentRequestCount    Int            @default(0)
  successfulPaymentCount Int            @default(0)
  overdueCount           Int            @default(0)
  platformInflow         Decimal        @default(0) @db.Decimal(14, 2)
  subscriptionRevenue    Decimal        @default(0) @db.Decimal(14, 2)
  commissionRevenue      Decimal        @default(0) @db.Decimal(14, 2)
  platformRevenue        Decimal        @default(0) @db.Decimal(14, 2)
  overdueAmount          Decimal        @default(0) @db.Decimal(14, 2)
  totalOutstandingAmount Decimal        @default(0) @db.Decimal(14, 2)
  overdueRecoveredAmount Decimal        @default(0) @db.Decimal(14, 2)
  avgDaysToCollect       Decimal?       @db.Decimal(8, 2)
  companyStatus          CompanyStatus?
  metadata               Json?
  company                Company?       @relation(fields: [companyId], references: [id])
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  @@unique([scope, scopeKey, bucketDate])
  @@index([scope, bucketDate])
  @@index([companyId, bucketDate])
}

model Plan {
  id              String                @id @default(cuid())
  code            String
  slug            String                @unique
  name            String
  description     String?
  interval        BillingInterval
  priceAmount     Decimal               @db.Decimal(12, 2)
  currency        String                @default("NGN")
  isActive        Boolean               @default(true)
  isPublic        Boolean               @default(true)
  canBeGranted    Boolean               @default(true)
  featureFlags    Json?
  allowances      Json?
  subscriptions   CompanySubscription[]
  commissionRules CommissionRule[]
  commissionRecords CommissionRecord[]
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@unique([code, interval])
  @@index([isActive, isPublic])
}

model CompanySubscription {
  id                     String             @id @default(cuid())
  companyId              String
  planId                 String
  status                 SubscriptionStatus @default(ACTIVE)
  interval               BillingInterval
  isCurrent              Boolean            @default(true)
  startsAt               DateTime
  endsAt                 DateTime?
  cancelledAt            DateTime?
  grantedByUserId        String?
  grantReason            String?
  externalSubscriptionId String?
  externalCustomerId     String?
  billingProvider        PaymentProviderCode?
  autoRenews             Boolean            @default(false)
  metadata               Json?
  company                Company            @relation(fields: [companyId], references: [id])
  plan                   Plan               @relation(fields: [planId], references: [id])
  grantedByUser          User?              @relation("GrantedSubscriptions", fields: [grantedByUserId], references: [id])
  commissionRecords      CommissionRecord[]
  billingEvents          BillingEvent[]
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  @@index([companyId, isCurrent, status])
  @@index([companyId, startsAt, endsAt])
  @@index([planId, status])
}

model CompanyBillingSettings {
  id                               String              @id @default(cuid())
  companyId                        String              @unique
  defaultCurrency                  String              @default("NGN")
  transactionProvider              PaymentProviderCode @default(PAYSTACK)
  subscriptionProvider             PaymentProviderCode?
  requireActivePlanForTransactions Boolean             @default(true)
  requireActivePlanForAdminOps     Boolean             @default(false)
  defaultCommissionRuleId          String?
  notes                            String?
  company                          Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  defaultCommissionRule            CommissionRule?     @relation("DefaultCommissionRule", fields: [defaultCommissionRuleId], references: [id])
  createdAt                        DateTime            @default(now())
  updatedAt                        DateTime            @updatedAt

  @@index([defaultCommissionRuleId])
}

model CompanyPaymentProviderAccount {
  id                       String                @id @default(cuid())
  companyId                String
  provider                 PaymentProviderCode
  displayName              String
  accountReference         String
  splitCode                String?
  subaccountCode           String?
  settlementCurrency       String                @default("NGN")
  settlementCountry        String?
  status                   ProviderAccountStatus @default(PENDING)
  supportsTransactionSplit Boolean               @default(false)
  supportsSubscriptions    Boolean               @default(false)
  isDefaultPayout          Boolean               @default(false)
  metadata                 Json?
  company                  Company               @relation(fields: [companyId], references: [id])
  splitSettlements         SplitSettlement[]
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt

  @@unique([companyId, provider, accountReference])
  @@index([companyId, provider, status])
}

model CommissionRule {
  id                String                   @id @default(cuid())
  companyId         String?
  planId            String?
  name              String
  code              String
  feeType           CommissionType          @default(FLAT)
  flatAmount        Decimal?                @db.Decimal(12, 2)
  percentageRate    Decimal?                @db.Decimal(5, 2)
  currency          String                  @default("NGN")
  isActive          Boolean                 @default(true)
  notes             String?
  company           Company?                @relation(fields: [companyId], references: [id])
  plan              Plan?                   @relation(fields: [planId], references: [id])
  billingSettings   CompanyBillingSettings[] @relation("DefaultCommissionRule")
  commissionRecords CommissionRecord[]
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  @@unique([companyId, code])
  @@index([planId, isActive])
  @@index([companyId, isActive])
}

model CommissionRecord {
  id                 String               @id @default(cuid())
  companyId          String
  paymentId          String               @unique
  transactionId      String?
  subscriptionId     String?
  planId             String?
  commissionRuleId   String?
  grossAmount        Decimal              @db.Decimal(12, 2)
  companyAmount      Decimal              @db.Decimal(12, 2)
  platformCommission Decimal              @db.Decimal(12, 2)
  providerFee        Decimal              @default(0) @db.Decimal(12, 2)
  netAmount          Decimal              @db.Decimal(12, 2)
  currency           String               @default("NGN")
  settlementStatus   SettlementStatus     @default(PENDING)
  metadata           Json?
  company            Company              @relation(fields: [companyId], references: [id])
  payment            Payment              @relation(fields: [paymentId], references: [id])
  transaction        Transaction?         @relation(fields: [transactionId], references: [id])
  subscription       CompanySubscription? @relation(fields: [subscriptionId], references: [id])
  plan               Plan?                @relation(fields: [planId], references: [id])
  commissionRule     CommissionRule?      @relation(fields: [commissionRuleId], references: [id])
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@index([companyId, settlementStatus, createdAt])
  @@index([companyId, subscriptionId])
  @@index([companyId, transactionId])
}

// ─── Marketer commission rules ─────────────────────────────────────────────
// Admins define how much each marketer earns when a payment is confirmed.
// Rules are matched by specificity: property > property type > company-wide.

model MarketerCommissionRule {
  id             String                @id @default(cuid())
  companyId      String
  name           String
  feeType        CommissionType        // FLAT | PERCENTAGE (reuse existing enum)
  flatAmount     Decimal?              @db.Decimal(12, 2)
  percentageRate Decimal?              @db.Decimal(5, 2)
  currency       String                @default("NGN")
  propertyType   PropertyType?         // null = applies to all property types
  propertyId     String?               // null = applies to all properties
  isActive       Boolean               @default(true)
  sortOrder      Int                   @default(0)
  company        Company               @relation("CompanyMarketerCommissionRules", fields: [companyId], references: [id])
  property       Property?             @relation("PropertyMarketerCommissionRules", fields: [propertyId], references: [id])
  commissions    MarketerCommission[]
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([companyId, isActive])
  @@index([companyId, propertyType, isActive])
  @@index([companyId, propertyId, isActive])
}

model MarketerCommission {
  id            String                   @id @default(cuid())
  companyId     String
  marketerId    String
  paymentId     String                   @unique
  transactionId String?
  ruleId        String?
  amount        Decimal                  @db.Decimal(12, 2)
  currency      String                   @default("NGN")
  status        MarketerCommissionStatus @default(PENDING)
  company       Company                  @relation("CompanyMarketerCommissions", fields: [companyId], references: [id])
  marketer      TeamMember               @relation("MarketerCommissions", fields: [marketerId], references: [id])
  payment       Payment                  @relation("PaymentMarketerCommission", fields: [paymentId], references: [id])
  transaction   Transaction?             @relation("TransactionMarketerCommissions", fields: [transactionId], references: [id])
  rule          MarketerCommissionRule?  @relation(fields: [ruleId], references: [id])
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  @@index([companyId, marketerId])
  @@index([companyId, status])
  @@index([marketerId, status, createdAt])
}

model SplitSettlement {
  id                  String                        @id @default(cuid())
  companyId           String
  paymentId           String                        @unique
  provider            PaymentProviderCode
  providerAccountId   String?
  grossAmount         Decimal                       @db.Decimal(12, 2)
  companyAmount       Decimal                       @db.Decimal(12, 2)
  platformAmount      Decimal                       @db.Decimal(12, 2)
  providerFee         Decimal                       @default(0) @db.Decimal(12, 2)
  currency            String                        @default("NGN")
  status              SettlementStatus              @default(PENDING)
  settlementReference String?
  metadata            Json?
  company             Company                       @relation(fields: [companyId], references: [id])
  payment             Payment                       @relation(fields: [paymentId], references: [id])
  providerAccount     CompanyPaymentProviderAccount? @relation(fields: [providerAccountId], references: [id])
  createdAt           DateTime                      @default(now())
  updatedAt           DateTime                      @updatedAt

  @@index([companyId, provider, status])
  @@index([providerAccountId])
}

model BillingEvent {
  id             String               @id @default(cuid())
  companyId      String?
  subscriptionId String?
  actorUserId    String?
  type           BillingEventType
  provider       PaymentProviderCode?
  amount         Decimal?             @db.Decimal(12, 2)
  currency       String?
  status         String?
  summary        String
  metadata       Json?
  company        Company?             @relation(fields: [companyId], references: [id])
  subscription   CompanySubscription? @relation(fields: [subscriptionId], references: [id])
  actorUser      User?                @relation("BillingEvents", fields: [actorUserId], references: [id])
  createdAt      DateTime             @default(now())

  @@index([companyId, type, createdAt])
  @@index([subscriptionId])
}

model Branch {
  id           String   @id @default(cuid())
  companyId    String
  name         String
  slug         String
  city         String?
  state        String?
  country      String?  @default("Nigeria")
  addressLine1 String?
  addressLine2 String?
  phone        String?
  email        String?
  company      Company  @relation(fields: [companyId], references: [id])
  users        User[]
  properties   Property[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([companyId, slug])
  @@index([companyId])
}

model User {
  id              String              @id @default(cuid())
  clerkUserId     String              @unique
  companyId       String?
  branchId        String?
  email           String              @unique
  firstName       String?
  lastName        String?
  phone           String?
  isActive        Boolean             @default(true)
  company         Company?            @relation(fields: [companyId], references: [id])
  branch          Branch?             @relation(fields: [branchId], references: [id])
  profile         Profile?
  roles           UserRole[]
  staffProfile    StaffProfile?
  savedProperties SavedProperty[] @relation("BuyerWishlists")
  inquiries       Inquiry[]
  reservations    Reservation[]
  transactions    Transaction[]
  payments        Payment[]
  paymentRequests PaymentRequest[]
  documents       Document[]
  inspectionBookings InspectionBooking[]
  notifications   Notification[]
  auditLogs       AuditLog[]
  activityEvents  ActivityEvent[]
  accessLogs      DocumentAccessLog[]
  kycSubmissions  KYCSubmission[]
  wishlistAssignments SavedProperty[] @relation("WishlistAssignedStaff")
  grantedSubscriptions CompanySubscription[] @relation("GrantedSubscriptions")
  billingEvents   BillingEvent[]        @relation("BillingEvents")
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([companyId])
  @@index([branchId])
}

model Role {
  id        String    @id @default(cuid())
  companyId String?
  name      AppRole
  label     String
  company   Company?  @relation(fields: [companyId], references: [id])
  users     UserRole[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([companyId, name])
  @@index([companyId])
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  companyId String?
