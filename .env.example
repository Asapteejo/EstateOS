# Core runtime
# Required for all environments.
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_PLATFORM_BASE_URL="http://localhost:3000"
NEXT_PUBLIC_PORTAL_BASE_URL="http://localhost:3000"
# Optional server alias. Set to https://estateos.tech in production.
APP_URL=""
APP_BASE_URL="http://localhost:3000"
PLATFORM_BASE_URL="http://localhost:3000"
PORTAL_BASE_URL="http://localhost:3000"
DEFAULT_COMPANY_SLUG="acme-realty"
ESTATEOS_ENABLE_DEV_BYPASS="false"
# Temporary safety guard while local development and production share a Supabase project.
PRODUCTION_DATABASE_PROJECT_REF="epxbejutuodmnsdfvcjr"
PRODUCTION_DATABASE_HOST="aws-0-eu-west-1.pooler.supabase.com"
ALLOW_PRODUCTION_DB_WRITES="false"
# Private platform-owner allowlist. Required to enable superadmin access in production.
SUPERADMIN_EMAILS=""

# Database
# Required when the database-backed app is enabled.
# Runtime should use the Supabase transaction-mode pooler on port 6543.
# For IPv4-only local development, it is acceptable to point BOTH DATABASE_URL and DIRECT_URL
# at the session-mode pooler on port 5432 so Prisma migrate/db pull can run locally.
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=5&sslmode=require"
# Prefer the true direct host in production-capable environments.
# If the direct host is unreachable locally, use the session-mode pooler on :5432 instead.
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require"

# Clerk
# Required in production when auth is enabled. Optional in local dev if using ESTATEOS_ENABLE_DEV_BYPASS.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
# Optional at startup. Required only for verified Clerk webhook ingestion.
CLERK_WEBHOOK_SECRET=""

# Paystack
# Optional. Leave blank to disable live payments safely.
PAYSTACK_SECRET_KEY=""
PAYSTACK_PUBLIC_KEY=""
PAYSTACK_WEBHOOK_SECRET=""
# Explicitly opt into simulated Paystack responses. Keep false in production.
PAYMENTS_DEMO_MODE="false"

# Cloudflare R2
# Optional. Leave blank to disable managed tenant asset storage.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_BASE_URL=""
# Optional but recommended for public branding/property assets. Private documents do not require it.

# Mapbox
# Optional. Leave blank to disable live maps.
MAPBOX_ACCESS_TOKEN=""
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=""

# Inngest
# Optional unless using Inngest-triggered jobs or event delivery.
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""
INNGEST_BASE_URL=""
CRON_SECRET=""

# Upstash Redis
# Optional. Leave blank to disable shared cache/rate-limit backing.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Resend
# Optional. Email falls back to no-op/demo behavior when unset.
RESEND_API_KEY=""
EMAIL_FROM="Acme Realty <no-reply@example.com>"

# Linear
# Optional. Leave blank to disable support/incident Linear sync.
LINEAR_API_KEY=""
LINEAR_TEAM_ID=""
LINEAR_SUPPORT_STATE_ID=""
LINEAR_BUG_LABEL_ID=""
LINEAR_FEATURE_REQUEST_LABEL_ID=""
LINEAR_QUESTION_LABEL_ID=""
LINEAR_BILLING_LABEL_ID=""
LINEAR_ONBOARDING_LABEL_ID=""
LINEAR_OTHER_LABEL_ID=""
LINEAR_HIGH_PRIORITY_LABEL_ID=""
LINEAR_MEDIUM_PRIORITY_LABEL_ID=""
LINEAR_LOW_PRIORITY_LABEL_ID=""

# PostHog
# Optional. Leave blank to disable PostHog capture safely.
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST=""
POSTHOG_PROJECT_API_KEY=""
POSTHOG_DISABLED="false"
POSTHOG_DEBUG="false"
NEXT_PUBLIC_POSTHOG_CLIENT_EXCEPTION_SAMPLE_RATE="0.5"
POSTHOG_SERVER_EXCEPTION_SAMPLE_RATE="1"

# Twilio WhatsApp
# Optional. TWILIO_WHATSAPP_FROM must include the "whatsapp:" prefix.
TWILIO_ENABLED="false"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"

# Gemini
# Optional. Used only for AI-assisted drafting / recommendations.
GEMINI_API_KEY=""

# Sentry
# Optional.
SENTRY_DSN=""
